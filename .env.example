# OANDA Configuration
OANDA_ACCOUNT_ID=xxx-xxx-xxxxxxx-xxx
OANDA_API_TOKEN=your-api-token-here
OANDA_ENV=practice

# Safety Controls
ENABLE_LIVE_TRADING=false

# Broker Selection
BROKER_TYPE=oanda
EXECUTION_MODE=paper

# Paper Trading
PAPER_BALANCE=1000000

# Risk Management
RISK_PER_TRADE=0.005
DAILY_LOSS_LIMIT=0.02
MAX_OPEN_POSITIONS=3
MAX_SPREAD_PIPS=2.0

# Trading Defaults
DEFAULT_SYMBOL=USD_JPY
DEFAULT_TIMEFRAME=M15
